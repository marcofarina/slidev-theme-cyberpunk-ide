{
  "name": "slidev-theme-cyberpunk-ide",
  "version": "0.1.4",
  "description": "A cyberpunk IDE-style Slidev theme for teaching computer science",
  "author": "Marco Farina",
  "license": "Unlicense",
  "type": "module",
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marcofarina/slidev-theme-cyberpunk-ide.git"
  },
  "homepage": "https://github.com/marcofarina/slidev-theme-cyberpunk-ide",
  "files": [
    "components/",
    "layouts/",
    "public/",
    "setup/",
    "styles/",
    "vite.config.ts",
    "README.md",
    "UNLICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "slidev build example.md",
    "dev": "slidev example.md --open",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png"
  },
  "dependencies": {
    "@slidev/types": "^52.14.1",
    "markdown-it-container": "^4.0.0"
  },
  "devDependencies": {
    "@slidev/cli": "^52.14.1",
    "@types/markdown-it-container": "^4.0.0"
  },
  "//": "Learn more: https://sli.dev/guide/write-theme.html",
  "slidev": {
    "colorSchema": "both",
    "defaults": {
      "lineNumbers": true,
      "fonts": {
        "sans": "Monaspace Neon",
        "mono": "Monaspace Neon",
        "local": [
          "Monaspace Neon",
          "Monaspace Radon"
        ],
        "provider": "none"
      }
    }
  }
}
